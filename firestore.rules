rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regra padrão: nega tudo por segurança
    match /{document=**} {
      allow read, write: if false;
    }

    // Regras para Grupos
    match /grupos/{groupId} {
      allow read: if true;
      allow write: if true;
    }

    // Regras para Campanhas
    match /campanhas/{campaignId} {
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    // Regras para Logs de Cliques
    match /cliques_log/{logId} {
      allow read: if true;
      allow create: if true;
    }
    // Regras para Nichos
    match /nichos/{nichoId} {
      allow read, write: if true;
    }
  }
}
